# --- Mark poller config ---

# The BSR app's base URL (no trailing slash). Replies are delivered here and the
# inbox is pulled from here.
APP_BASE_URL=https://your-bsr-app.vercel.app

# Bearer token for GET/POST /api/v1/hermes/messages — same value as the app's
# HERMES_AGENT_API_TOKEN.
HERMES_AGENT_API_TOKEN=

# How many messages to drain per run (default 5).
MARK_POLL_LIMIT=5

# --- Phase 2 (webhook push) — used by webhook.py for instant replies ---
# Shared secret, identical to the app's MARK_WEBHOOK_SECRET, used to verify the
# X-Webhook-Signature HMAC on inbound wakes. Generate one and set the SAME value
# here and in the app (Vercel). Leave blank only for loopback/dev.
MARK_WEBHOOK_SECRET=
# Where webhook.py listens. The app's MARK_RUNNER_URL must be the public HTTPS
# URL that tunnels to http://<this-host>:MARK_WEBHOOK_PORT{MARK_WEBHOOK_PATH}.
MARK_WEBHOOK_PORT=8644
MARK_WEBHOOK_PATH=/webhooks/growth-chat

# --- MCP server (mcp_server.py) ---
# Exposes the Mark Operations API as agent tools. Reuses HERMES_AGENT_API_TOKEN
# above. BSR_MARKETING_BASE_URL is preferred; it falls back to APP_BASE_URL.
BSR_MARKETING_BASE_URL=https://bsr-marketing.vercel.app
