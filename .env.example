# Supabase — without these the app still validates/scores but does not persist
# (lead ingest returns 202 "not_configured"; read-models report "unavailable").
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth (all optional in local dev; set in any shared/prod deployment) ---

# Required to enable the Arc agent API. POST /api/v1/arc/runs refuses with
# 503 until this is set, then requires `Authorization: Bearer <token>`.
ARC_AGENT_API_TOKEN=

# --- Arc chat (event-driven wake) ---
# When an operator sends Arc a chat message, the app POSTs a small event
# `{ type: "arc_chat_message", operator, conversationId, agentTaskId, route,
#    mentions, message }` to ARC_RUNNER_URL so Arc processes just that message
# and then sleeps — no background/LLM polling. The wake is best-effort: if it
# doesn't land, the message stays queued and Arc catches up via
# GET /api/v1/arc/messages.
#   ARC_RUNNER_URL      — Arc runner webhook route, e.g. https://host:8644/webhooks/growth-chat.
#                         Leave UNSET to disable the push and rely on the inbox poll.
#                         (Legacy alias ARC_WEBHOOK_URL is still read as a fallback.)
#   ARC_WEBHOOK_SECRET  — shared secret. When set, the request body is signed with
#                         HMAC-SHA256 and sent as the `X-Webhook-Signature` header.
#   ARC_DISPLAY_NAME    — what the attached agent is called in the UI. Defaults to "Arc".
#                         (The agent key to attach to is resolved from the DB
#                         agent_connections record, not an env var.)
ARC_RUNNER_URL=
ARC_WEBHOOK_SECRET=
ARC_DISPLAY_NAME=

# Reference-image uploads (Google Cloud Storage). The browser uploads straight
# to the bucket via a v4 signed URL; image bytes never touch the app server.
# Leave UNSET to disable photo uploads (the attach button reports "not configured").
#   GCS_BUCKET               — your bucket name.
#   GCS_SERVICE_ACCOUNT_KEY  — the service-account JSON, base64-encoded (single line).
#                              PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("key.json"))
#                              bash:       base64 -w0 key.json
GCS_BUCKET=
GCS_SERVICE_ACCOUNT_KEY=

# AI image generation (Arc `generate_image`, Google Gemini 2.5 Flash Image).
# OFF by default. Both must be set (Supabase already required), or Arc reports
# "image generation isn't enabled" and makes no external call. Generated images
# are stored in the public `campaign-media` Supabase bucket, tagged ai_generated,
# risk-flagged, and land as approval-gated draft assets. (No GCS needed.)
#   ARC_MEDIA_ENABLED  — master switch; set to "1" to enable.
#   GEMINI_API_KEY     — Google Gemini API key (needs billing for image output).
#   GEMINI_IMAGE_MODEL — optional model override. Default: imagen-4.0-generate-001
#                        (best photoreal text-to-image). Other options:
#                        imagen-4.0-ultra-generate-001 (max quality, slower/pricier),
#                        gemini-2.5-flash-image (Nano Banana: editing + reference images).
#   GEMINI_VIDEO_MODEL — optional Veo model for `generate_video`. Default:
#                        veo-2.0-generate-001. Set a Veo 3 id for higher quality.
#   GEMINI_EMBEDDING_MODEL — optional override for the Brain semantic-memory
#                        embedding model. Default: gemini-embedding-2 (current GA).
#                        NB: text-embedding-004 was shut down 2026-01-14 and
#                        gemini-embedding-001 retires 2026-07-14 — don't use them.
#                        Output is pinned to 768 dims to match pgvector. The Brain
#                        "Refresh memory" button reports which model works.
ARC_MEDIA_ENABLED=
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=
GEMINI_VIDEO_MODEL=
GEMINI_EMBEDDING_MODEL=

# Optional bearer token for POST /api/v1/leads/ingest. When UNSET the endpoint
# stays open (dev/back-compat). When SET, ingest requires a matching bearer token.
LEADS_INGEST_API_TOKEN=

# Bearer token for POST /api/v1/campaigns/results (campaign analytics ingest). Optional; when unset the endpoint stays open in dev.
CAMPAIGN_RESULTS_API_TOKEN=

# Cosmetic only: names the synthetic org in the offline demo context (ARC_DEMO_DATA).
# It does NOT select a tenant. A session-less request resolves the sole org in the
# database, and refuses when there is more than one rather than guessing.
DEFAULT_ORG_SLUG=big-shoulders-restoration

# Auth gate — controls whether visitors must sign in before any app screen.
#   supabase = REQUIRE SIGN-IN (full accounts + workspaces). Unauthenticated
#              requests to any /build-* screen (or the real routes) redirect to
#              /login; static assets and the auth pages stay public. This is the
#              intended production mode now that the auth screens are live.
#              Requires the Supabase URL + anon key above.
#   operator = legacy shared operator gate (OPERATOR_* below).
#   open     = NO login, every page public (local demo / preview only).
# NOTE: if supabase/operator is requested but its config is missing, the app
# safely falls back to "open" (logs a warning) so a misconfig can't lock everyone
# out. In production this env lives on Vercel, not in this file.
ARC_AUTH_MODE=supabase
# OPERATOR_ACCESS_TOKEN is the server-only session cookie secret; operators enter
# OPERATOR_EMAIL and OPERATOR_PASSWORD on the login screen.
# Example generator: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
OPERATOR_ACCESS_TOKEN=
OPERATOR_EMAIL=
OPERATOR_PASSWORD=
OPERATOR_SUPPORT_EMAIL=

# --- Connections (outbound integrations) ---

# Resend email. Without RESEND_API_KEY the Connections panel shows Resend as
# "not configured" and every send is blocked. RESEND_FROM MUST be an address on a
# domain you've verified in Resend (DKIM/SPF/DMARC), e.g. "Arc <hello@yourdomain.com>";
# it is the branded from-address for invites and other transactional sends.
# NOTE: these belong on Vercel + local only. Do NOT set RESEND_* on the Cloud Run
# runner — the runner sends no email; the app performs every Resend send.
# For campaign sends the from-address comes from the Resend connection row's
# config.fromEmail (set via `pnpm configure:resend`); RESEND_FROM is the fallback.
RESEND_API_KEY=
RESEND_FROM="Big Shoulders Restoration <arc@mail.bsr-restoration.com>"

# ARC_SEND_ENABLED — master kill-switch for REAL outbound campaign sends
# (executeResendDispatch). Leave BLANK and campaign email never leaves the
# building, no matter what else is configured. Set to "1" only when you are
# deliberately ready to send for real (then send one test to yourself first).
# This is on top of the per-send approval gate and the per-connection toggle.
ARC_SEND_ENABLED=

# ARC_OPPORTUNITY_CONFIDENCE_FLOOR — minimum confidence (0-100) an opportunity
# must score to reach the inbox. Leave BLANK for the default (50 baseline, with
# crm_inactivity held to 60 since it out-produces every other detector combined).
# Raise it for a workspace whose inbox is still too noisy; it lifts every kind,
# including ones with their own higher floor. Detection is unaffected — this
# filters what gets persisted, and the count rejected is reported, never silent.
ARC_OPPORTUNITY_CONFIDENCE_FLOOR=

# Stripe billing (Tier-3). The platform pays all provider API credits and bills
# each tenant; plans + monthly caps live in org_plans and are enforced against the
# ai_usage_events ledger. Leave STRIPE_SECRET_KEY blank and all billing UI/actions
# are hidden and the Settings plan picker falls back to a manual (dev/comp) override.
#   1. Create one recurring monthly Price per paid tier in the Stripe dashboard and
#      paste the price ids below (free has no price).
#   2. Add a webhook endpoint -> https://your-app.example.com/api/webhooks/stripe
#      subscribed to customer.subscription.created/updated/deleted; paste its
#      signing secret as STRIPE_WEBHOOK_SECRET.
#   3. Set ARC_BILLING_ENFORCEMENT=1 (see below) only when you want caps to BLOCK.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=
# Absolute app URL used to build Checkout/Portal return links. When unset it is
# derived from the request host.
NEXT_PUBLIC_APP_URL=

# ARC_BILLING_ENFORCEMENT — master switch for BLOCKING over-cap usage. Leave BLANK
# and quotas are computed/displayed but never block (safe default). Set to "1" to
# actually refuse Arc runs / media generation once an org is over its monthly cap.
ARC_BILLING_ENFORCEMENT=

# Optional: branding for `pnpm email:export` (the hosted Supabase auth template
# generator). Defaults to "Arc" with no logo when unset.
EMAIL_EXPORT_APP_NAME=
EMAIL_EXPORT_LOGO_URL=

# Google Drive manual import. Create the app-level Google OAuth client and add the callback:
#   https://your-app.example.com/api/integrations/google-drive/callback
# GOOGLE_DRIVE_REDIRECT_URI is optional; when unset, the app derives the callback
# from the current origin. Each operator connects their own Google account at
# runtime; Drive imports are manual selected-file copies into Library, not
# background folder sync.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=
# Required for the in-app "Choose from Drive" browser. The API key should be
# restricted to the Google Picker API / Drive API and your app domains. The app
# id is the Google Cloud project number, not the OAuth client id.
GOOGLE_DRIVE_PICKER_API_KEY=
GOOGLE_DRIVE_APP_ID=

# Social connections (placeholders; posting transport ships in a later spec).
# Full acquisition steps: docs/social-connections-setup.md. Status in the Connections
# panel flips to "Connected" once ALL of a provider's vars below are set.

# Meta — ONE app powers both Facebook Page + Instagram Business publishing.
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=               # Facebook Page to post as  → gates Facebook
META_PAGE_ACCESS_TOKEN=     # long-lived Page token     → gates Facebook + Instagram
META_IG_USER_ID=            # Instagram Business acct id → gates Instagram

# LinkedIn — OAuth2 access token + the org page to post as.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_URN=           # e.g. urn:li:organization:12345

# X (Twitter) — OAuth 1.0a user context (write access).
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Weather Signals connector (NWS/NOAA) — signal_source, no API key required.
# api.weather.gov asks every client to send a descriptive User-Agent with a
# contact. Optional: a sensible default is used if unset. Format is free-form,
# e.g. "MyApp/1.0 (contact: ops@example.com)".
NWS_USER_AGENT=

# Scheduled opportunity scan (proactive Arc, slice 2)
# CRON_SECRET is set in Vercel and auto-sent by Vercel Cron as `Authorization: Bearer <CRON_SECRET>`.
# The cron route requires it (fail-closed). Leave unset locally.
CRON_SECRET=
# Set to 1 in prod to enable the daily scheduled scan (off by default).
OPPORTUNITY_SCAN_CRON_ENABLED=

# --- Error tracking (Sentry) -------------------------------------------------
# Everything below is OPTIONAL. With no DSN, Sentry initializes disabled and
# sends nothing — local dev, the demo preview, and CI are unaffected. Set the DSN
# in Vercel to turn it on; no redeploy of code is needed, just a rebuild.
#
# The DSN is public by design (it ships in the browser bundle) — it identifies the
# project, it is not a secret.
NEXT_PUBLIC_SENTRY_DSN=
# Overrides the auto-detected environment (defaults to VERCEL_ENV, else "development").
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# 0–1. Defaults to 0.1 — errors are the point; traces bill per event. Anything
# blank/invalid falls back to the default rather than silently becoming 0.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=

# Source-map upload at build time (so prod stack traces show real lines, not
# minified soup). Only used when SENTRY_AUTH_TOKEN is present — the build is a
# clean pass-through without it, which is how CI builds env-less.
# SENTRY_AUTH_TOKEN *is* a secret; keep it out of the client.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
