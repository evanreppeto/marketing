# Supabase — without these the app still validates/scores but does not persist
# (lead ingest returns 202 "not_configured"; read-models report "unavailable").
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth (all optional in local dev; set in any shared/prod deployment) ---

# Required to enable the Hermes agent API. POST /api/v1/hermes/runs refuses with
# 503 until this is set, then requires `Authorization: Bearer <token>`.
HERMES_AGENT_API_TOKEN=

# --- Mark chat (event-driven wake) ---
# When an operator sends Mark a chat message, the app POSTs a small event
# `{ type: "mark_chat_message", operator, conversationId, agentTaskId, route,
#    mentions, message }` to MARK_RUNNER_URL so Mark processes just that message
# and then sleeps — no background/LLM polling. The wake is best-effort: if it
# doesn't land, the message stays queued and Mark catches up via
# GET /api/v1/hermes/messages.
#   MARK_RUNNER_URL     — Mark/Hermes runner webhook route, e.g. https://host:8644/webhooks/growth-chat.
#                         Leave UNSET to disable the push and rely on the inbox poll.
#                         (Legacy alias MARK_WEBHOOK_URL is still read as a fallback.)
#   MARK_WEBHOOK_SECRET — shared secret. When set, the request body is signed with
#                         HMAC-SHA256 and sent as the `X-Webhook-Signature` header.
MARK_RUNNER_URL=
MARK_WEBHOOK_SECRET=

# Optional bearer token for POST /api/v1/leads/ingest. When UNSET the endpoint
# stays open (dev/back-compat). When SET, ingest requires a matching bearer token.
LEADS_INGEST_API_TOKEN=

# Bearer token for POST /api/v1/campaigns/results (campaign analytics ingest). Optional; when unset the endpoint stays open in dev.
CAMPAIGN_RESULTS_API_TOKEN=

# Operator console access gate. When OPERATOR_ACCESS_TOKEN is UNSET, all pages
# are open (local dev). When SET, every page route requires sign-in at /sign-in.
# OPERATOR_ACCESS_TOKEN is the server-only session cookie secret; operators enter
# OPERATOR_EMAIL and OPERATOR_PASSWORD on the login screen.
# Example generator: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
OPERATOR_ACCESS_TOKEN=
OPERATOR_EMAIL=
OPERATOR_PASSWORD=
OPERATOR_SUPPORT_EMAIL=

# --- Connections (outbound integrations) ---

# Resend email. Without RESEND_API_KEY the Connections panel shows Resend as
# "not configured" and every send is blocked. RESEND_FROM is the verified
# from-address used for sends (and the "Send test email" self-test, which falls
# back to OPERATOR_EMAIL for the recipient).
RESEND_API_KEY=
RESEND_FROM=
