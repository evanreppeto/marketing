# Supabase — without these the app still validates/scores but does not persist
# (lead ingest returns 202 "not_configured"; read-models report "unavailable").
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth (all optional in local dev; set in any shared/prod deployment) ---

# Required to enable the Arc agent API. POST /api/v1/arc/runs refuses with
# 503 until this is set, then requires `Authorization: Bearer <token>`.
ARC_AGENT_API_TOKEN=

# --- Arc chat (event-driven wake) ---
# When an operator sends Arc a chat message, the app POSTs a small event
# `{ type: "arc_chat_message", operator, conversationId, agentTaskId, route,
#    mentions, message }` to ARC_RUNNER_URL so Arc processes just that message
# and then sleeps — no background/LLM polling. The wake is best-effort: if it
# doesn't land, the message stays queued and Arc catches up via
# GET /api/v1/arc/messages.
#   ARC_RUNNER_URL      — Arc runner webhook route, e.g. https://host:8644/webhooks/growth-chat.
#                         Leave UNSET to disable the push and rely on the inbox poll.
#                         (Legacy alias ARC_WEBHOOK_URL is still read as a fallback.)
#   ARC_WEBHOOK_SECRET  — shared secret. When set, the request body is signed with
#                         HMAC-SHA256 and sent as the `X-Webhook-Signature` header.
#   ARC_DISPLAY_NAME    — what the attached agent is called in the UI. Defaults to "Arc".
#                         (The agent key to attach to is resolved from the DB
#                         agent_connections record, not an env var.)
ARC_RUNNER_URL=
ARC_WEBHOOK_SECRET=
ARC_DISPLAY_NAME=

# Reference-image uploads (Google Cloud Storage). The browser uploads straight
# to the bucket via a v4 signed URL; image bytes never touch the app server.
# Leave UNSET to disable photo uploads (the attach button reports "not configured").
#   GCS_BUCKET               — your bucket name.
#   GCS_SERVICE_ACCOUNT_KEY  — the service-account JSON, base64-encoded (single line).
#                              PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("key.json"))
#                              bash:       base64 -w0 key.json
GCS_BUCKET=
GCS_SERVICE_ACCOUNT_KEY=

# AI image generation (Arc `generate_image`, Google Gemini 2.5 Flash Image).
# OFF by default. Both must be set (Supabase already required), or Arc reports
# "image generation isn't enabled" and makes no external call. Generated images
# are stored in the public `campaign-media` Supabase bucket, tagged ai_generated,
# risk-flagged, and land as approval-gated draft assets. (No GCS needed.)
#   ARC_MEDIA_ENABLED  — master switch; set to "1" to enable.
#   GEMINI_API_KEY     — Google Gemini API key (needs billing for image output).
#   GEMINI_IMAGE_MODEL — optional model override. Default: imagen-4.0-generate-001
#                        (best photoreal text-to-image). Other options:
#                        imagen-4.0-ultra-generate-001 (max quality, slower/pricier),
#                        gemini-2.5-flash-image (Nano Banana: editing + reference images).
#   GEMINI_VIDEO_MODEL — optional Veo model for `generate_video`. Default:
#                        veo-2.0-generate-001. Set a Veo 3 id for higher quality.
ARC_MEDIA_ENABLED=
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=
GEMINI_VIDEO_MODEL=

# Optional bearer token for POST /api/v1/leads/ingest. When UNSET the endpoint
# stays open (dev/back-compat). When SET, ingest requires a matching bearer token.
LEADS_INGEST_API_TOKEN=

# Bearer token for POST /api/v1/campaigns/results (campaign analytics ingest). Optional; when unset the endpoint stays open in dev.
CAMPAIGN_RESULTS_API_TOKEN=

# Optional: which seeded organization the single deployment serves (multi-tenant chokepoint).
DEFAULT_ORG_SLUG=big-shoulders-restoration

# Operator console access gate. Leave ARC_AUTH_MODE empty/open to keep login
# hidden and all pages open while the auth screens are still being polished.
# Set ARC_AUTH_MODE=supabase to enable Supabase Auth after the Supabase URL,
# anon key, and OAuth redirect URLs are configured. Set ARC_AUTH_MODE=operator
# to enable the legacy shared operator gate below.
ARC_AUTH_MODE=open
# OPERATOR_ACCESS_TOKEN is the server-only session cookie secret; operators enter
# OPERATOR_EMAIL and OPERATOR_PASSWORD on the login screen.
# Example generator: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
OPERATOR_ACCESS_TOKEN=
OPERATOR_EMAIL=
OPERATOR_PASSWORD=
OPERATOR_SUPPORT_EMAIL=

# --- Connections (outbound integrations) ---

# Resend email. Without RESEND_API_KEY the Connections panel shows Resend as
# "not configured" and every send is blocked. RESEND_FROM is the verified
# from-address used for sends (and the "Send test email" self-test, which falls
# back to OPERATOR_EMAIL for the recipient).
RESEND_API_KEY=
RESEND_FROM=

# Social connections (placeholders; posting transport ships in a later spec).
# Full acquisition steps: docs/social-connections-setup.md. Status in the Connections
# panel flips to "Connected" once ALL of a provider's vars below are set.

# Meta — ONE app powers both Facebook Page + Instagram Business publishing.
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=               # Facebook Page to post as  → gates Facebook
META_PAGE_ACCESS_TOKEN=     # long-lived Page token     → gates Facebook + Instagram
META_IG_USER_ID=            # Instagram Business acct id → gates Instagram

# LinkedIn — OAuth2 access token + the org page to post as.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_URN=           # e.g. urn:li:organization:12345

# X (Twitter) — OAuth 1.0a user context (write access).
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
