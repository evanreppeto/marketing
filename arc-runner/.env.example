# --- Arc poller config ---

# The BSR app's base URL (no trailing slash). Replies are delivered here and the
# inbox is pulled from here.
APP_BASE_URL=https://your-bsr-app.vercel.app

# Bearer token for GET/POST /api/v1/arc/messages — same value as the app's
# ARC_AGENT_API_TOKEN.
ARC_AGENT_API_TOKEN=

# How many messages to drain per run (default 5).
ARC_POLL_LIMIT=5

# --- Phase 2 (webhook push) — used by webhook.py for instant replies ---
# Shared secret, identical to the app's ARC_WEBHOOK_SECRET, used to verify the
# X-Webhook-Signature HMAC on inbound wakes. Generate one and set the SAME value
# here and in the app (Vercel). Leave blank only for loopback/dev.
ARC_WEBHOOK_SECRET=
# Where webhook.py listens. The app's ARC_RUNNER_URL must be the public HTTPS
# URL that tunnels to http://<this-host>:ARC_WEBHOOK_PORT{ARC_WEBHOOK_PATH}.
ARC_WEBHOOK_PORT=8644
ARC_WEBHOOK_PATH=/webhooks/growth-chat

# --- MCP server (mcp_server.py) ---
# Exposes the Arc Operations API as agent tools. Reuses ARC_AGENT_API_TOKEN
# above. BSR_MARKETING_BASE_URL is preferred; it falls back to APP_BASE_URL.
BSR_MARKETING_BASE_URL=https://bsr-marketing.vercel.app

# --- Phase 3 (realtime push) — used by realtime_subscriber.py for instant replies ---
# The subscriber opens an OUTBOUND WebSocket to Supabase (no public URL / tunnel
# needed) and subscribes to agent_tasks inserts. SUPABASE_URL is your project URL;
# the service-role key authorizes the realtime subscription and the CAS claim and
# lives only on this trusted host.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Module exposing generate_reply(message) and deliver(agentTaskId, text, status).
# Defaults to the reference poller; point it at Arc's real worker module if different.
ARC_WORKER_MODULE=poller
