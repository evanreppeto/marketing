<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.bsr.arc-realtime</string>

  <!-- Loads .env from the working dir, then runs the subscriber. -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>set -a; . ./.env; set +a; exec "__PYTHON__" realtime_subscriber.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__ARC_RUNNER_DIR__</string>

  <!-- Restart on crash and start at load/login. -->
  <key>KeepAlive</key>
  <true/>
  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>__ARC_RUNNER_DIR__/arc-realtime.log</string>
  <key>StandardErrorPath</key>
  <string>__ARC_RUNNER_DIR__/arc-realtime.err.log</string>
</dict>
</plist>
