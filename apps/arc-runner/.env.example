# --- Arc runner (bridge) configuration ---

# Base URL of the Growth Engine app the bridge reports back to.
# Local: http://localhost:3000
APP_API_BASE_URL=http://localhost:3000

# Bearer token for the app's Mark Operations API (/api/v1/hermes/*). Make one up;
# set the SAME value as the app's HERMES_AGENT_API_TOKEN.
HERMES_AGENT_API_TOKEN=

# Shared secret to verify the app's wake. Set the SAME value as the app's
# MARK_WEBHOOK_SECRET. Leave unset only for trusted local testing.
MARK_WEBHOOK_SECRET=

# --- Arc's brain: Claude subscription auth (NOT an API key) ---
# Run `claude setup-token` (after `npm i -g @anthropic-ai/claude-code` + logging
# in with your Max plan). Paste the sk-ant-oat01-... token here.
CLAUDE_CODE_OAUTH_TOKEN=
# IMPORTANT: make sure ANTHROPIC_API_KEY is NOT set in this environment, or it
# silently overrides the OAuth token and bills API credits instead of your plan.

# Model for chat replies. Fast model keeps replies snappy.
ARC_MODEL=claude-haiku-4-5

# HTTP port the bridge listens on. Point the app's MARK_RUNNER_URL at
# http://localhost:<PORT>/webhooks/growth-chat
PORT=8788
WEBHOOK_PATH=/webhooks/growth-chat
