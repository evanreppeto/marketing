# --- Arc runner (bridge) configuration ---

# Base URL of the Growth Engine app the bridge reports back to.
# Local: http://localhost:3000
APP_API_BASE_URL=http://localhost:3000

# Bearer token for the app's Arc Operations API (/api/v1/arc/*). Make one up;
# set the SAME value as the app's ARC_AGENT_API_TOKEN.
ARC_AGENT_API_TOKEN=

# Shared secret to verify the app's wake. Set the SAME value as the app's
# webhook secret. Leave unset only for trusted local testing.
ARC_WEBHOOK_SECRET=

# --- Arc's brain: Claude subscription auth (NOT an API key) ---
# Run `claude setup-token` (after `npm i -g @anthropic-ai/claude-code` + logging
# in with your Max plan). Paste the sk-ant-oat01-... token here.
CLAUDE_CODE_OAUTH_TOKEN=
# IMPORTANT: make sure ANTHROPIC_API_KEY is NOT set in this environment, or it
# silently overrides the OAuth token and bills API credits instead of your plan.

# Model for chat replies. Fast model keeps replies snappy.
ARC_MODEL=claude-haiku-4-5

# HTTP port the runner listens on. Point the app's ARC_RUNNER_URL at
# http://localhost:<PORT>/webhooks/growth-chat
PORT=8788
WEBHOOK_PATH=/webhooks/growth-chat

# --- Error tracking (Sentry) — optional ---------------------------------------
# Without a DSN the runner initializes Sentry disabled and sends nothing, so dev
# and tests are unaffected. Set it on the Cloud Run service to turn it on:
#   gcloud run services update arc-runner --update-env-vars SENTRY_DSN=<dsn>
# (or add it to --set-env-vars in deploy-cloud-run.sh).
#
# This is the service where a silent failure hurts most: a failed run currently
# only reaches console.error → Cloud Logging, which nobody is watching.
# The DSN identifies the project; it is not a secret.
SENTRY_DSN=
# Overrides the auto-detected environment (Cloud Run's K_SERVICE ⇒ "production",
# otherwise "development").
SENTRY_ENVIRONMENT=
# 0–1. Defaults to 0.1; blank/invalid falls back to the default rather than 0.
SENTRY_TRACES_SAMPLE_RATE=
